// CloudBase 浜戝嚱鏁板湴鍧€锛堜唬鐞嗙鍩烘祦鍔?API锛岄殣钘?API Key锛?const CLOUDBASE_FUNCTION_URL = 'https://vibud-1gcx4a5580370c2f-1305515347.ap-shanghai.app.tcloudbase.com/xinya-ai';

interface AIResponse {
  text: string;
  suggestions?: string[];
  logicAnalysis?: UserLogicAnalysis;
}

// 鐢ㄦ埛閫昏緫鍒嗘瀽缁撴灉
interface UserLogicAnalysis {
  isCircular: boolean;           // 鏄惁闄峰叆寰幆
  circularPattern?: string;       // 寰幆妯″紡
  isAvoiding: boolean;            // 鏄惁鍦ㄥ洖閬?  avoidanceTopic?: string;        // 鍥為伩鐨勮瘽棰?  breakthroughAttempted: boolean; // 鏄惁宸插皾璇曠獊鐮?  breakthroughQuestion?: string; // 绐佺牬鎬ф彁闂?  emotionalState: string;          // 褰撳墠鎯呯华鐘舵€?  suggestion: string;             // 寤鸿鐨勫紩瀵肩瓥鐣?}

// 鐢ㄦ埛閫昏緫鐢诲儚锛堝唴瀛樹腑锛?interface UserLogicProfile {
  messageCount: number;           // 娑堟伅璁℃暟
  recentMessages: string[];        // 鏈€杩慛鏉℃秷鎭?  repeatedPhrases: Map<string, number>; // 閲嶅鍙ュ紡
  avoidanceTopics: Set<string>;   // 鍥為伩鐨勮瘽棰?  lastTopic: string | null;       // 涓婁竴涓瘽棰?  topicStreak: number;             // 璇濋杩炵画娆℃暟
  totalCircularCount: number;     // 绱寰幆娆℃暟
  breakthroughAttempts: number;  // 绐佺牬灏濊瘯娆℃暟
  effectiveBreakthroughs: number; // 鏈夋晥绐佺牬娆℃暟
}

// 寰幆琛ㄨ揪妫€娴嬮槇鍊?const CIRCULAR_THRESHOLD = 2;     // 鍚屼竴鍙ヨ瘽鍑虹幇2娆¤涓哄惊鐜?const TOPIC_STREAK_LIMIT = 3;      // 璇濋杩炵画3娆¤涓哄惊鐜?
// 甯歌鍥為伩妯″紡
const AVOIDANCE_PATTERNS = [
  { pattern: '涓嶆兂璇?, topic: '鍥為伩娣卞害' },
  { pattern: '娌′粈涔?, topic: '鎯呮劅闅旂' },
  { pattern: '绠椾簡', topic: '鏀惧純琛ㄨ揪' },
  { pattern: '灏辫繖鏍峰惂', topic: '鏀惧純琛ㄨ揪' },
  { pattern: '浣犱笉鎳?, topic: '闃插尽鎬? },
  { pattern: '璇翠簡涔熸病鐢?, topic: '涔犲緱鎬ф棤鍔? },
  { pattern: '涓嶇煡閬?, topic: '鎯呮劅闅旂' },
  { pattern: '鎴戜笉鎯虫彁', topic: '鍥為伩娣卞害' },
  { pattern: '鍒棶浜?, topic: '闃插尽鎬? },
];

// 绐佺牬璇濇湳搴?const BREAKTHROUGH_QUESTIONS: Record<string, string[]> = {
  '鎯呮劅闅旂': [
    '鎴戝彧鏄兂鏇村ソ鍦扮悊瑙ｄ綘锛屽鏋滀笉鎯宠涔熸病鍏崇郴',
    '浠€涔堟椂鍊欏彲浠ヨ锛熸垨鑰呮垜浠崲涓瘽棰橈紵',
  ],
  '闃插尽鎬?: [
    '鎴戞病鏈夎璇勫垽浣犵殑鎰忔€?,
    '浣犵煡閬撳悧锛屾湁鏃跺€欒涓嶅嚭鍙ｇ殑璇濓紝姝ｆ槸鏈€鎯宠鍚埌鐨?,
  ],
  '涔犲緱鎬ф棤鍔?: [
    '涔熻璇村嚭鏉ヤ笉鑳芥敼鍙樼粨鏋滐紝浣嗚鍑烘潵鏈韩灏辨槸涓€绉嶅姏閲?,
    '浣犳効鎰忚瘯璇曠湅鍚楋紵鍝€曡涓€鍙?,
  ],
  '鍥為伩娣卞害': [
    '鎴戞敞鎰忓埌浣犲ソ鍍忎笉澶兂璇磋繖涓紝鏄湁浠€涔堥【铏戝悧锛?,
    '娌″叧绯荤殑锛屾垜浠彲浠ユ參鎱㈡潵',
  ],
  '鏀惧純琛ㄨ揪': [
    '濡傛灉浣犲噯澶囧ソ浜嗭紝鎴戦殢鏃跺湪杩欓噷',
    '浣犳兂鍏堝仠涓€鍋滀篃鍙互锛屾垜浼氶櫔鐫€浣?,
