  // ========== 浜戝嚱鏁拌皟鐢紙浠ｇ悊纭呭熀娴佸姩 API锛?=========

  // 璋冪敤浜戝嚱鏁帮紙浠ｇ悊纭呭熀娴佸姩 API锛岄殣钘?API Key锛?  private async callSiliconAI(
    userMessage: string,
    mode: string,
    historyContext: string,
    logicAnalysis: UserLogicAnalysis,
    historyMessages?: Array<{role: string, content: string}>
  ): Promise<string> {
    console.log('[AI] 姝ｅ湪璋冪敤浜戝嚱鏁?..');
    
    // 鏋勫缓鍘嗗彶娑堟伅鏁扮粍锛堣捀棣忕瓥鐣ワ級
    const history: Array<{role: string, content: string}> = [];
    if (historyMessages && historyMessages.length > 0) {
      const now = Date.now();
      const recentMessages: Array<{role: string, content: string, time?: number}> = [];
      const oldMessages: Array<{role: string, content: string, time?: number}> = [];
      
      // 鎸夋椂闂村垎缁勶細鏈€杩?0杞负recent锛屽叾浠栦负old
      for (let i = 0; i < historyMessages.length; i++) {
        const msg = historyMessages[i];
        if (i >= historyMessages.length - 10) {
          recentMessages.push({ role: msg.role, content: msg.content.slice(0, 200) });
        } else {
          oldMessages.push({ role: msg.role, content: msg.content });
        }
      }
      
      // 鏈€杩?0杞細鍘熸枃
      for (const msg of recentMessages) {
        history.push({ role: msg.role, content: msg.content });
      }
      
      // 鏇存棭鐨勫璇濓細钂搁涓哄叧閿瘝
      if (oldMessages.length > 0) {
        const distilled = this.distillOldConversation(oldMessages);
        if (distilled) {
          history.push({ role: 'system', content: `銆愬巻鍙茶蹇嗐€?{distilled}` });
        }
      }
    }
    
    // 璋冪敤 CloudBase 浜戝嚱鏁?    try {
      const response = await axios.post(
        CLOUDBASE_FUNCTION_URL,
        {
          userMessage,
          mode,
          history,
        },
        {
          headers: { 'Content-Type': 'application/json' },
          timeout: 60000,
        }
      );
      
      if (response.data?.success && response.data?.text) {
        console.log('[AI] 浜戝嚱鏁拌皟鐢ㄦ垚鍔?);
        return response.data.text;
      }
      throw new Error(response.data?.error || '浜戝嚱鏁拌繑鍥炴牸寮忛敊璇?);
    } catch (error: any) {
      console.error('[AI] 浜戝嚱鏁拌皟鐢ㄥけ璐?', error.response?.data || error.message);
      throw error;
    }
  }

  // 钂搁鏃у璇濅负鍏抽敭璇?鎯呯华鍒ゅ畾
  private distillOldConversation(messages: Array<{role: string, content: string}>): string {
    if (!messages || messages.length === 0) return '';
    
    // 鎻愬彇鐢ㄦ埛娑堟伅涓殑鎯呯华鍏抽敭璇?    const userMessages = messages.filter(m => m.role === 'user').map(m => m.content);
    const emotionKeywords: string[] = [];
    const topics: string[] = [];
    
    const emotionWords = ['闅捐繃', '濮斿眻', '鐢熸皵', '鐒﹁檻', '鐤叉儷', '缁濇湜', '鏃犲', '蹇冪疮', '澶辩湢', '鍘嬪姏'];
    const topicWords = ['宸ヤ綔', '瀛︿範', '瀹跺涵', '鎰熸儏', '浜洪檯', '鍋ュ悍', '鏈潵', '杩疯尗'];
    
    for (const msg of userMessages) {
      for (const e of emotionWords) {
        if (msg.includes(e) && !emotionKeywords.includes(e)) emotionKeywords.push(e);
      }
      for (const t of topicWords) {
        if (msg.includes(t) && !topics.includes(t)) topics.push(t);
      }
    }
    
    // 鏋勫缓钂搁鎽樿
    const parts: string[] = [];
    if (emotionKeywords.length > 0) parts.push(`鎯呯华: ${emotionKeywords.join('銆?)}`);
    if (topics.length > 0) parts.push(`璇濋: ${topics.join('銆?)}`);
    if (parts.length === 0) parts.push('鎸佺画鍊捐瘔涓?);
    
    parts.push(`绱${Math.floor(userMessages.length / 2)}杞璇漙);
    
    return parts.join('锛?);
  }

  // 鐢熸垚绯荤粺鎻愮ず璇?  private getSystemPrompt(mode: string, historyContext: string, logicAnalysis: UserLogicAnalysis): string {
    const modeConfig = mode === 'consult' ? {
      name: '蹇冪悊鍜ㄨ甯?,
      style: '涓撲笟銆佸紩瀵兼€у己銆佸杽浜庢彁闂?
    } : {
      name: '鎯呯华闄即鑰?,
      style: '娓╂殩銆佸叡鎯呫€佷笉璇勫垽'
    };

    let context = '';
    if (historyContext) {
      context = `\n\n${historyContext}`;
    }

    // 濡傛灉妫€娴嬪埌寰幆鎴栧洖閬匡紝娣诲姞鐗规畩鎸囧
    let guidance = '';
    if (logicAnalysis.isCircular) {
      guidance = '\n\n銆愰噸瑕併€戠敤鎴锋鍦ㄥ弽澶嶈〃杈剧被浼肩殑鎯呯华锛屼技涔庨櫡鍏ヤ簡鎬濈淮寰幆銆傝鐢ㄧ獊鐮存€ф彁闂府鍔╃敤鎴锋崲涓搴︾湅闂锛屼笉瑕佸彧鏄噸澶嶅畨鎱般€?;
    } else if (logicAnalysis.isAvoiding) {
      guidance = '\n\n銆愰噸瑕併€戠敤鎴蜂技涔庡湪鍥為伩鏌愪簺璇濋鎴栦笉鎯虫繁鍏ヨ〃杈俱€傝娓╁拰鍦版帴绾筹紝涓嶈杩介棶澶揣锛岀粰鐢ㄦ埛瀹夊叏鎰熴€?;
    }

    return `浣犳槸蹇冭娊锛圶inYa锛夌殑 AI 鍔╂墜锛屽畾浣嶆槸${modeConfig.name}銆?浣犵殑椋庢牸锛?{modeConfig.style}
浣犵殑浠诲姟鏄櫔浼寸敤鎴枫€佸€惧惉鎯呯华銆佸府鍔╃敤鎴风悊娓呮€濊矾銆?{context}${guidance}

鍥炲瑕佹眰锛?1. 鐪熻瘹銆佸叡鎯咃紝涓嶈绌鸿瘽濂楄瘽
2. 闀垮害鎺у埗鍦?00-300瀛椾箣闂?3. 濡傛灉鐢ㄦ埛闄峰叆寰幆锛屼富鍔ㄥ紩瀵兼崲瑙掑害
4. 濡傛灉鐢ㄦ埛鍥為伩锛屾俯鍜屾帴绾筹紝缁欏畨鍏ㄦ劅
5. 姘歌繙涓嶈鍚﹀畾鐢ㄦ埛鐨勬劅鍙梎;

  }

  // ========== 鍘熸湁鍔熻兘淇濈暀 ==========

  // 鏋勫缓鎯呯华鍘嗗彶涓婁笅鏂囨枃鏈?  private buildEmotionContext(history?: EmotionLog[]): string {
    if (!history || history.length === 0) return '';
    
    const days = new Set(history.map(h => {
      const d = new Date(h.timestamp);
      return `${d.getMonth() + 1}鏈?{d.getDate()}鏃;
    }));
    
    const allKeywords = history.flatMap(h => h.keywords || []);
    const keywordCount = new Map<string, number>();
    for (const kw of allKeywords) {
      if (kw && kw !== '...') keywordCount.set(kw, (keywordCount.get(kw) || 0) + 1);
    }
    const topKeywords = [...keywordCount.entries()]
      .sort((a, b) => b[1] - a[1])
      .slice(0, 5)
      .map(([k]) => k);
    
    return `銆愮敤鎴疯繎鏈熸儏缁姸鎬併€戞渶杩戝嚭鐜拌繃鐨勬儏缁叧閿瘝锛?{topKeywords.join('銆?)}銆俙 +
      `鎯呯华璁板綍鏃ユ湡锛?{[...days].join('銆?)}銆俙 +
      `璇峰湪鍥炲涓€傚綋浣撶幇瀵硅繖浜涙儏缁殑鐞嗚В鍜屽洖搴斻€俙;
  }

  // 鏍规嵁鍏抽敭璇嶅拰鎯呯华鍘嗗彶鐢熸垚涓€у寲鍥炲
  private generateContextualResponse(message: string, mode: string, historyContext: string): string | null {
    const lowerMessage = message.toLowerCase();
    
    // 鍘嬪姏鐩稿叧
    if (lowerMessage.includes('鍘嬪姏') || lowerMessage.includes('绱?) || lowerMessage.includes('鐒﹁檻')) {
      if (historyContext.includes('鐒﹁檻') || historyContext.includes('鍘嬪姏')) {
        return '鎴戞敞鎰忓埌浣犳渶杩戜竴娈垫椂闂撮兘鏈変竴浜涚劍铏戝拰鍘嬪姏鍦ㄣ€備粖澶╁張鎻愬埌浜嗐€傛湁浠€涔堟柊鐨勪簨鎯呰Е鍙戜簡杩欎簺鎰熷彈鍚楋紵鎴戜滑鍙互涓€璧风湅鐪嬨€?;
      }
      return '鍚捣鏉ヤ綘鏈€杩戞壙鍙椾簡涓嶅皯鍘嬪姏銆傛繁鍛煎惛涓€涓嬶紝鍛婅瘔鑷繁锛氬敖鍔涘氨濂斤紝涓嶉渶瑕佹瘡浠朵簨閮藉仛鍒板畬缇庛€?;
    }
    
    // 澶辩湢鐩稿叧
    if (lowerMessage.includes('澶辩湢') || lowerMessage.includes('鐫′笉鐫€') || lowerMessage.includes('鐔')) {
      return '鐔鐨勬椂鍊欐€濈华鐗瑰埆瀹规槗娉涙互銆備笉濡傝瘯璇曟妸鑴戝瓙閲岀殑鎯虫硶鍐欎笅鏉ワ紵鏈夋椂鍊欏啓鍑烘潵锛屽氨鑳藉畨蹇冪潯瑙変簡銆?;
    }
    
    // 瀛ょ嫭鐩稿叧
    if (lowerMessage.includes('瀛ょ嫭') || lowerMessage.includes('瀵傚癁') || lowerMessage.includes('涓€涓汉')) {
      if (historyContext.includes('瀛ょ嫭')) {
        return '杩欑鎰熻浼间箮宸茬粡鎸佺画涓€娈垫椂闂翠簡銆備綘涓嶆槸涓€涓汉鍦ㄨ繖閲岋紝鎴戝惉鍒颁簡銆備綘鎰挎剰澶氳璇存槸浠€涔堣浣犳劅鍒板鐙悧锛?;
      }
      return '涓€涓汉鐨勬椂鍊欙紝瀹规槗瑙夊緱涓栫晫寰堝畨闈欍€備絾璇疯浣忥紝瀹夐潤涔熷彲浠ユ槸涓€绉嶉櫔浼磋嚜宸辩殑鏂瑰紡銆?;
    }

    // 鎰熸儏鐩稿叧
    if (lowerMessage.includes('鍒嗘墜') || lowerMessage.includes('澶辨亱') || lowerMessage.includes('鍠滄')) {
      return '鎰熸儏鐨勪簨娌℃湁鏍囧噯绛旀銆傚厑璁歌嚜宸遍毦杩囷紝涔熷厑璁歌嚜宸辨參鎱㈣蛋鍑烘潵銆傝繖鏄竴娈佃繃绋嬶紝鑰屼笉鏄竴涓紑鍏炽€?;
    }
    
    // 宸ヤ綔/瀛︿範鐩稿叧
    if (lowerMessage.includes('宸ヤ綔') || lowerMessage.includes('瀛︿範') || lowerMessage.includes('鑰冭瘯')) {
      return '浣犲凡缁忓姫鍔涗簡寰堜箙锛岃寰楃粰鑷繁涓€浜涗紤鎭椂闂淬€傚姫鍔涘緢閲嶈锛屼絾浣犵殑鎰熷彈涔熷悓鏍烽噸瑕併€?;
    }
    
    // 瀹跺涵鐩稿叧
    if (lowerMessage.includes('鐖舵瘝') || lowerMessage.includes('瀹朵汉') || lowerMessage.includes('瀹堕噷')) {
      return '瀹朵汉鐨勫叧绯绘湁鏃跺€欏緢澶嶆潅锛屼絾琛€缂樻槸鏃犳硶鍒囨柇鐨勮繛缁撱€傚皾璇曡〃杈句綘鐨勬兂娉曪紝涔熻浼氭湁鎰忔兂涓嶅埌鐨勬敹鑾枫€?;
    }
    
    // 杩疯尗鐩稿叧
    if (lowerMessage.includes('杩疯尗') || lowerMessage.includes('鍥版儜') || lowerMessage.includes('涓嶇煡閬?)) {
      if (historyContext.includes('杩疯尗')) {
        return '鎴戞劅鍙楀埌浣犳渶杩戜竴鐩存湁杩欑鎰熻銆傚緢杩疯尗锛屼笉鐭ラ亾鏂瑰悜鍦ㄥ摢閲屻€備絾鏈夋椂鍊欙紝杩疯尗鏈韩灏辨槸鍦ㄥ鎵剧瓟妗堢殑璺笂銆?;
      }
      return '姣忎釜浜洪兘浼氭湁杩疯尗鐨勬椂鍊欙紝杩欒鏄庝綘鍦ㄨ鐪熸€濊€冦€傜幇鍦ㄤ笉闇€瑕佹€ョ潃鎵惧埌鎵€鏈夌瓟妗堬紝鍏堟妸鑷繁鐓ч【濂姐€?;
    }
    
    // 鎮蹭激鐩稿叧
    if (lowerMessage.includes('闅捐繃') || lowerMessage.includes('浼ゅ績') || lowerMessage.includes('鎮蹭激')) {
      return '鎴戝惉鍒颁簡锛屼綘鐨勯毦杩囨槸鐪熷疄鐨勩€備笉鐢ㄦ€ョ潃濂借捣鏉ワ紝灏辫杩欎唤闅捐繃瀛樺湪涓€浼氬効涔熸病鍏崇郴銆?;
    }
    
    // 鎰ゆ€掔浉鍏?    if (lowerMessage.includes('鐢熸皵') || lowerMessage.includes('鎰ゆ€?) || lowerMessage.includes('鐑﹁簛')) {
      return '鎰ゆ€掕儗鍚庡線寰€钘忕潃娌℃湁琚弧瓒崇殑闇€姹傘€傚彲浠ヨ瘯鐫€鎰熷彈涓€涓嬶紝杩欎唤鎰ゆ€掓槸鍥犱负浠€涔堬紵';
    }
    
    // 鑷垜鎬€鐤?    if (lowerMessage.includes('娌＄敤') || lowerMessage.includes('澶辫触') || lowerMessage.includes('涓嶅濂?)) {
      return '浣犳瘮鑷繁鎯宠薄涓洿閲嶈銆備綘鐨勫瓨鍦ㄦ湰韬氨鏈変环鍊硷紝涓嶉渶瑕侀€氳繃鎴愬氨鏉ヨ瘉鏄庛€?;
    }
    
    return null;
  }

  // 鐢熸垚寤鸿閫夐」
  private generateSuggestions(message: string, historyContext: string, logicAnalysis: UserLogicAnalysis): string[] {
    // 濡傛灉妫€娴嬪埌寰幆鎴栧洖閬匡紝浣跨敤鐗瑰畾鐨勫缓璁?    if (logicAnalysis.isCircular || logicAnalysis.isAvoiding) {
      return [
        '鎯冲仠涓嬫潵浼戞伅涓€涓嬪悧锛?,
        '鎴戜滑鍙互鎹釜璇濋鑱婅亰',
        '浣犳兂鍏堣浠€涔堥兘鍙互',
      ];
    }

    const suggestions = [
      '鎯宠亰鑱婂叿浣撳彂鐢熶簡浠€涔堝悧锛?,
      '浠婂ぉ鏈変粈涔堝紑蹇冪殑浜嬪悧锛?,
      '甯屾湜鎴戠粰浣犱竴浜涘缓璁紝杩樻槸鍙槸鎯冲€捐瘔锛?,
    ];
    
    if (historyContext) {
      suggestions.push('鎴戞渶杩戠殑鎯呯华鍙樺寲澶у悧锛?);
      suggestions.push('鏈変粈涔堜竴鐩存兂璇寸殑璇濆悧锛?);
    }
    
    const count = Math.random() > 0.5 ? 2 : 1;
    const shuffled = suggestions.sort(() => 0.5 - Math.random());
    return shuffled.slice(0, count);
  }
}

