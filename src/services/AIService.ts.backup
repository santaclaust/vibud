// AI鏈嶅姟 - 娌绘剤绯籄I鍥炲锛屾敮鎸佹儏缁巻鍙蹭笂涓嬫枃鍜岀敤鎴烽€昏緫鍒嗘瀽
import axios from 'axios';
import { EmotionLog, callFunction } from './CloudBaseService';
