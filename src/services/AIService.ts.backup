};

class AIService {
  // 鐢ㄦ埛閫昏緫鐢诲儚锛堟寜userId瀛樺偍锛?  private userProfiles: Map<string, UserLogicProfile> = new Map();

  // 鑾峰彇鐢ㄦ埛鐢诲儚
  private getUserProfile(userId: string): UserLogicProfile {
    if (!this.userProfiles.has(userId)) {
      this.userProfiles.set(userId, {
        messageCount: 0,
        recentMessages: [],
        repeatedPhrases: new Map(),
        avoidanceTopics: new Set(),
        lastTopic: null,
        topicStreak: 0,
        totalCircularCount: 0,
        breakthroughAttempts: 0,
        effectiveBreakthroughs: 0,
      });
    }
    return this.userProfiles.get(userId)!;
  }

  // 閲嶇疆鐢ㄦ埛鐢诲儚
  resetUserProfile(userId: string) {
    this.userProfiles.delete(userId);
  }

  // 鑾峰彇AI鍥炲锛堟敮鎸佹儏缁巻鍙蹭笂涓嬫枃銆佺敤鎴烽€昏緫鍒嗘瀽鍜屼釜鎬у寲鐢诲儚锛?  async getResponse(
    userMessage: string,
    mode: 'heal' | 'consult',
    emotionHistory?: EmotionLog[],
    userId?: string,
    messages?: { role: string; content: string }[]  // 瀵硅瘽鍘嗗彶锛岀敤浜庣敓鎴愭憳瑕?  ): Promise<AIResponse> {
    // 鑾峰彇鐢ㄦ埛鐢诲儚涓婁笅鏂?    let profileContext = '';
    if (userId) {
      try {
        profileContext = await getProfileSummaryForAI(userId);
      } catch (e) {
        console.log('[AI] 鑾峰彇鐢ㄦ埛鐢诲儚澶辫触:', e);
      }
    }
    
    // 鏋勫缓鎯呯华鍘嗗彶涓婁笅鏂?    const historyContext = this.buildEmotionContext(emotionHistory);
    
    // 鍚堝苟涓婁笅鏂囷細鐢ㄦ埛鐢诲儚 + 鎯呯华鍘嗗彶
    const fullContext = profileContext + (historyContext ? '\n\n' + historyContext : '');
    
    // 鍒嗘瀽鐢ㄦ埛閫昏緫
    const logicAnalysis = this.analyzeUserLogic(userMessage, userId);
    
    // 鏍规嵁閫昏緫鍒嗘瀽缁撴灉璋冩暣鍥炲绛栫暐
    let responseText: string;
    if (logicAnalysis.breakthroughAttempted) {
      // 宸茬粡灏濊瘯杩囩獊鐮达紝浣跨敤娓╁拰鍥炲簲
      responseText = this.generateGentleResponse(logicAnalysis);
    } else if (logicAnalysis.isCircular) {
      // 闄峰叆寰幆锛屼娇鐢ㄧ獊鐮存€ц瘽鏈?      responseText = logicAnalysis.breakthroughQuestion || '...';
      if (userId) {
        const profile = this.getUserProfile(userId);
        profile.breakthroughAttempts++;
      }
    } else if (logicAnalysis.isAvoiding) {
      // 鍦ㄥ洖閬匡紝浣跨敤寮曞鎬ц瘽鏈?      responseText = this.generateAvoidanceResponse(logicAnalysis);
      if (userId) {
        const profile = this.getUserProfile(userId);
        profile.breakthroughAttempts++;
        profile.avoidanceTopics.add(logicAnalysis.avoidanceTopic!);
      }
    } else {
      // 姝ｅ父瀵硅瘽锛岃皟鐢ㄧ鍩烘祦鍔?AI锛堜紶鍏ョ敤鎴风敾鍍忎笂涓嬫枃鍜屽璇濆巻鍙诧級
      try {
        responseText = await this.callSiliconAI(userMessage, mode, fullContext, logicAnalysis, messages);
      } catch (error) {
        console.error('[AI] AI璋冪敤澶辫触锛屼娇鐢ㄥ鐢ㄥ洖澶?', error);
        const customResponse = this.generateContextualResponse(userMessage, mode, fullContext);
        const baseResponses = mode === 'consult' ? CONSULT_RESPONSES : HEAL_RESPONSES;
        responseText = customResponse || baseResponses[Math.floor(Math.random() * baseResponses.length)];
      }
    }
    
    console.log('[AI] 鍥炲鍐呭:', responseText.slice(0, 50) + '...');
    
    // 濡傛灉鏈夌敤鎴稩D鍜屽璇濆巻鍙诧紝鐢熸垚浼氳瘽鎽樿 + 瀛︿範鐢ㄦ埛椋庢牸锛堝紓姝ワ紝涓嶉樆濉炲洖澶嶏級
    if (userId && messages && messages.length > 0) {
      this.saveSessionSummary(userId, messages, logicAnalysis).catch(e => 
        console.log('[AI] 淇濆瓨浼氳瘽鎽樿澶辫触:', e)
      );
      // 瀛︿範鐢ㄦ埛鍋忓ソ椋庢牸
      this.learnUserStyle(userId, messages, responseText).catch(e =>
        console.log('[AI] 瀛︿範鐢ㄦ埛椋庢牸澶辫触:', e)
      );
    }
    
    return {
      text: responseText,
      suggestions: this.generateSuggestions(userMessage, fullContext, logicAnalysis),
      logicAnalysis,
    };
  }
  
  // 淇濆瓨浼氳瘽鎽樿
  private async saveSessionSummary(
    userId: string,
    messages: { role: string; content: string }[],
    logicAnalysis: UserLogicAnalysis
  ): Promise<void> {
    // 鎻愬彇鏈瀵硅瘽鐨勬儏缁叧閿瘝
    const emotions = logicAnalysis.emotionalState ? [logicAnalysis.emotionalState] : [];
    
    // 鎻愬彇璇濋锛堢畝鍖栫増锛氬彇鐢ㄦ埛娑堟伅涓殑鍏抽敭璇嶏級
    const topics = this.extractTopicsFromMessages(messages);
    
    const summary = generateSessionSummary(
      `session_${Date.now()}`,
      messages,
      emotions,
      topics,
      logicAnalysis.isCircular,
      logicAnalysis.breakthroughAttempted
    );
    
    await addSessionSummary(userId, summary);
    console.log('[AI] 浼氳瘽鎽樿宸蹭繚瀛?);
  }
  
  // 浠庢秷鎭腑鎻愬彇璇濋
  private extractTopicsFromMessages(messages: { role: string; content: string }[]): string[] {
    const topicKeywords = {
      '宸ヤ綔': ['宸ヤ綔', '涓婄彮', '涓嬬彮', '鍔犵彮', '杈炶亴', '闈㈣瘯'],
      '鎰熸儏': ['鎭嬬埍', '鍒嗘墜', '缁撳', '绂诲', '鐩镐翰', '鍑鸿建'],
      '瀹跺涵': ['鐖舵瘝', '瀹朵汉', '瀛╁瓙', '鑰佸叕', '鑰佸﹩', '浜叉垰'],
      '瀛︿笟': ['瀛︿範', '鑰冭瘯', '鑰冪爺', '鐣欏', '鎴愮哗', '浣滀笟'],
      '鍋ュ悍': ['澶辩湢', '鐒﹁檻', '鎶戦儊', '韬綋', '鍖婚櫌', '鐪嬬梾'],
      '璐㈠姟': ['閽?, '宸ヨ祫', '鐞嗚储', '鎶曡祫', '璐熷€?, '瀛樻'],
    };
    
    const userMessages = messages.filter(m => m.role === 'user');
    const allText = userMessages.map(m => m.content).join('');
    
    const foundTopics: string[] = [];
    for (const [topic, keywords] of Object.entries(topicKeywords)) {
      if (keywords.some(kw => allText.includes(kw))) {
        foundTopics.push(topic);
      }
    }
    
    return foundTopics;
  }
  
  // 瀛︿範鐢ㄦ埛鍋忓ソ椋庢牸锛堝垵濮嬪寲鏃惰皟鐢級
  private async learnUserStyle(
    userId: string,
    messages: { role: string; content: string }[],
    lastResponse: string
  ): Promise<void> {
    const { learnUserTone } = await import('./UserProfileService');
    
    // 鍒嗙鐢ㄦ埛鍜?AI 鐨勬秷鎭?    const userMessages = messages.filter(m => m.role === 'user').map(m => m.content);
    const aiResponses = messages.filter(m => m.role === 'assistant').map(m => m.content);
    
    if (userMessages.length >= 3) {
      await learnUserTone(userId, userMessages, aiResponses);
    }
  }

  // ========== 鐢ㄦ埛閫昏緫鍒嗘瀽鏍稿績 ==========

  // 鍒嗘瀽鐢ㄦ埛閫昏緫
  private analyzeUserLogic(userMessage: string, userId?: string): UserLogicAnalysis {
    const profile = userId ? this.getUserProfile(userId) : null;
    const result: UserLogicAnalysis = {
      isCircular: false,
      isAvoiding: false,
      breakthroughAttempted: false,
      emotionalState: this.detectEmotion(userMessage),
      suggestion: 'normal',
    };

    // 1. 妫€娴嬫儏缁姸鎬?    result.emotionalState = this.detectEmotion(userMessage);

    // 2. 妫€娴嬪惊鐜ā寮?    if (profile) {
      const circularResult = this.detectCircularPattern(userMessage, profile);
      if (circularResult.isCircular) {
        result.isCircular = true;
        result.circularPattern = circularResult.pattern;
        result.suggestion = 'breakthrough';
      }
    }

    // 3. 妫€娴嬪洖閬?闃插尽
    const avoidanceResult = this.detectAvoidance(userMessage);
    if (avoidanceResult.isAvoiding) {
      result.isAvoiding = true;
      result.avoidanceTopic = avoidanceResult.topic;
      if (!result.isCircular) {
        result.suggestion = 'guide';
      }
    }

    // 4. 妫€鏌ユ槸鍚﹀凡灏濊瘯杩囩獊鐮?    if (profile && profile.breakthroughAttempts > 0) {
      result.breakthroughAttempted = true;
    }

    // 5. 鐢熸垚绐佺牬鎬ф彁闂?    if (result.isCircular || result.isAvoiding) {
      result.breakthroughQuestion = this.generateBreakthroughQuestion(
        result.isCircular ? 'circular' : result.avoidanceTopic!
      );
    }

    return result;
  }

  // 妫€娴嬫儏缁姸鎬?  private detectEmotion(message: string): string {
    const lower = message.toLowerCase();
    if (lower.includes('鐒﹁檻') || lower.includes('绱у紶') || lower.includes('鎷呭績')) return '鐒﹁檻';
    if (lower.includes('闅捐繃') || lower.includes('浼ゅ績') || lower.includes('鎮蹭激')) return '鎮蹭激';
    if (lower.includes('鐢熸皵') || lower.includes('鎰ゆ€?) || lower.includes('鐑﹁簛')) return '鎰ゆ€?;
    if (lower.includes('瀛ょ嫭') || lower.includes('瀵傚癁')) return '瀛ょ嫭';
    if (lower.includes('杩疯尗') || lower.includes('鍥版儜') || lower.includes('涓嶇煡鎵€鎺?)) return '杩疯尗';
    if (lower.includes('瀹虫€?) || lower.includes('鎭愭儳') || lower.includes('鎬?)) return '鎭愭儳';
    if (lower.includes('鏃犲') || lower.includes('缁濇湜') || lower.includes('鏃犲姏')) return '缁濇湜';
    if (lower.includes('寮€蹇?) || lower.includes('楂樺叴') || lower.includes('蹇箰')) return '寮€蹇?;
    return '骞抽潤';
  }

  // 妫€娴嬪惊鐜ā寮?  private detectCircularPattern(message: string, profile: UserLogicProfile): { isCircular: boolean; pattern?: string } {
    profile.messageCount++;
    profile.recentMessages.push(message);
    if (profile.recentMessages.length > 10) profile.recentMessages.shift();

    // 绠€鍖栨鏌ワ細鎻愬彇鍏抽敭鍙ュ紡锛堝彇鍓?0涓瓧绗︼級
    const phrase = message.slice(0, 20).replace(/[锛屻€傦紵锛乚/g, '').trim();
    if (!phrase) return { isCircular: false };

    // 妫€鏌ラ噸澶嶅彞寮?    const count = (profile.repeatedPhrases.get(phrase) || 0) + 1;
    profile.repeatedPhrases.set(phrase, count);

    if (count >= CIRCULAR_THRESHOLD) {
      profile.totalCircularCount++;
      return { isCircular: true, pattern: phrase };
    }

    // 妫€鏌ヨ瘽棰樿繛缁?    const currentTopic = this.extractTopic(message);
    if (currentTopic === profile.lastTopic) {
      profile.topicStreak++;
      if (profile.topicStreak >= TOPIC_STREAK_LIMIT) {
        return { isCircular: true, pattern: currentTopic };
      }
    } else {
      profile.topicStreak = 0;
      profile.lastTopic = currentTopic;
    }

    return { isCircular: false };
  }

  // 鎻愬彇璇濋
  private extractTopic(message: string): string {
    const lower = message.toLowerCase();
    if (lower.includes('宸ヤ綔') || lower.includes('涓婄彮')) return '宸ヤ綔';
    if (lower.includes('鎰熸儏') || lower.includes('鎭嬬埍') || lower.includes('鍒嗘墜')) return '鎰熸儏';
    if (lower.includes('鐖舵瘝') || lower.includes('瀹朵汉') || lower.includes('瀹堕噷')) return '瀹跺涵';
    if (lower.includes('鏈嬪弸')) return '浜洪檯鍏崇郴';
    if (lower.includes('閽?) || lower.includes('缁忔祹')) return '缁忔祹';
    if (lower.includes('澶辩湢') || lower.includes('鐫¤') || lower.includes('绱?)) return '鐘舵€?;
    return '鍏朵粬';
  }

  // 妫€娴嬪洖閬?闃插尽鏈哄埗
  private detectAvoidance(message: string): { isAvoiding: boolean; topic?: string } {
    for (const { pattern, topic } of AVOIDANCE_PATTERNS) {
      if (message.includes(pattern)) {
        return { isAvoiding: true, topic };
      }
    }
    return { isAvoiding: false };
  }

  // 鐢熸垚绐佺牬鎬ф彁闂?  private generateBreakthroughQuestion(trigger: string): string {
    if (trigger === 'circular') {
      const questions = [
        '鎴戞敞鎰忓埌浣犺浜嗗緢澶氱被浼肩殑鎰熷彈銆備綘鎰挎剰鍛婅瘔鎴戯紝鏄粈涔堣浣犱竴鐩村湪杩欎欢浜嬮噷鍑轰笉鏉ュ悧锛?,
        '浣犳弿杩扮殑杩欎簺锛屾垜寰堟兂鐭ラ亾锛氬鏋滅敤涓€涓瘝鏉ュ舰瀹逛綘鐜板湪鏈€澶х殑鎰熷彈锛岄偅浼氭槸浠€涔堬紵',
        '鍚捣鏉ヤ綘鍦ㄨ繖浠朵簨閲屽崱浜嗗緢涔呫€傚鏋滅幇鍦ㄦ湁涓€浠朵簨鍙互鍋氱偣浠€涔堬紝浣犱細甯屾湜鏄粈涔堬紵',
        '鎴戝彂鐜颁綘璇存潵璇村幓閮芥槸鍚屼竴涓棶棰樸€傛湁鏃跺€欙紝鎴戜滑闇€瑕佺殑涓嶆槸绛旀锛岃€屾槸鎹釜瑙掑害鐪嬮棶棰樸€備綘鎰挎剰璇曡瘯鍚楋紵',
      ];
      return questions[Math.floor(Math.random() * questions.length)];
    }

    const questions = BREAKTHROUGH_QUESTIONS[trigger] || [
      '鎴戝惉鍒颁簡锛屼綘鎯冲仠涓嬫潵銆傚彲浠ュ憡璇夋垜鏄粈涔堣浣犱笉鎯崇户缁鍚楋紵',
    ];
    return questions[Math.floor(Math.random() * questions.length)];
  }

